### Pull summary stats from the saved models

# make empty dataframes
slope.sum <- data.frame("slope" = double(), "slope.sd" = double(),"slope.p" = double())
maxsum.sum <- data.frame("max.sum" = double(),"max.sum.sd" = double(),"max.sum.p" = double())
sumdays21.sum <- data.frame("sum.days.above.21"= double(),"sum.days.above.21.sd"= double(),"sum.days.above.21.p"= double())
minwin.sum <- data.frame("min.wint"= double(),"min.wint.sd"= double(),"min.wint.p"= double())
windaysneg5.sum <- data.frame("wint.days.below.neg5"= double(),"wint.days.below.neg5.sd"= double(),"wint.days.below.neg5.p"= double())
avgEVI.sum <- data.frame("avgEVI.lag"= double(),"avgEVI.lag.sd"= double(),"avgEVI.lag.p"= double())
sden.sum <- data.frame("sden.mean"= double(), "sden.mean.sd"= double(), "sden.mean.p"= double())
perm.sum <- data.frame("perm"= double(),"perm.sd"= double(),"perm.p"= double())
windaysabove0.sum <- data.frame("wint.days.above.0"= double(),"wint.days.above.0.sd"= double(),"wint.days.above.0.p"= double())

for(j in 1:length(list)){
  if("slope" %in% colnames(list[[j]]$model)) {
    slope.sum[j,"slope"] <- list[[j]]$coefficients["slope"]                     # estimate
    slope.sum[j,"slope.sd"] <- coef(summary(list[[j]]))[,"Std. Error"]["slope"] # std. error
    slope.sum[j,"slope.p"] <- coef(summary(list[[j]]))[,"Pr(>|z|)"]["slope"]    # p-value 
  }
  if("max.sum" %in% colnames(list[[j]]$model)) {
    maxsum.sum[j,"max.sum"] <- list[[j]]$coefficients["max.sum"]                     # estimate
    maxsum.sum[j,"max.sum.sd"] <- coef(summary(list[[j]]))[,"Std. Error"]["max.sum"] # std. error
    maxsum.sum[j,"max.sum.p"] <- coef(summary(list[[j]]))[,"Pr(>|z|)"]["max.sum"]    # p-value 
  }
  if("sum.days.above.21" %in% colnames(list[[j]]$model)) {
    sumdays21.sum[j,"sum.days.above.21"] <- list[[j]]$coefficients["sum.days.above.21"]                     # estimate
    sumdays21.sum[j,"sum.days.above.21.sd"] <- coef(summary(list[[j]]))[,"Std. Error"]["sum.days.above.21"] # std. error
    sumdays21.sum[j,"sum.days.above.21.p"] <- coef(summary(list[[j]]))[,"Pr(>|z|)"]["sum.days.above.21"]    # p-value 
  }
  if("min.wint" %in% colnames(list[[j]]$model)) {
    minwin.sum[j,"min.wint"] <- list[[j]]$coefficients["min.wint"]                     # estimate
    minwin.sum[j,"min.wint.sd"] <- coef(summary(list[[j]]))[,"Std. Error"]["min.wint"] # std. error
    minwin.sum[j,"min.wint.p"] <- coef(summary(list[[j]]))[,"Pr(>|z|)"]["min.wint"]    # p-value 
  }
  if("wint.days.below.neg5" %in% colnames(list[[j]]$model)) {
    windaysneg5.sum[j,"wint.days.below.neg5"] <- list[[j]]$coefficients["wint.days.below.neg5"]                     # estimate
    windaysneg5.sum[j,"wint.days.below.neg5.sd"] <- coef(summary(list[[j]]))[,"Std. Error"]["wint.days.below.neg5"] # std. error
    windaysneg5.sum[j,"wint.days.below.neg5.p"] <- coef(summary(list[[j]]))[,"Pr(>|z|)"]["wint.days.below.neg5"]    # p-value 
  }
  if("avgEVI.lag" %in% colnames(list[[j]]$model)) {
    avgEVI.sum[j,"avgEVI.lag"] <- list[[j]]$coefficients["avgEVI.lag"]                     # estimate
    avgEVI.sum[j,"avgEVI.lag.sd"] <- coef(summary(list[[j]]))[,"Std. Error"]["avgEVI.lag"] # std. error
    avgEVI.sum[j,"avgEVI.lag.p"] <- coef(summary(list[[j]]))[,"Pr(>|z|)"]["avgEVI.lag"]    # p-value 
  }
  if("sden.mean" %in% colnames(list[[j]]$model)) {
    sden.sum[j,"sden.mean"] <- list[[j]]$coefficients["sden.mean"]                     # estimate
    sden.sum[j,"sden.mean.sd"] <- coef(summary(list[[j]]))[,"Std. Error"]["sden.mean"] # std. error
    sden.sum[j,"sden.mean.p"] <- coef(summary(list[[j]]))[,"Pr(>|z|)"]["sden.mean"]    # p-value 
  }
  if("perm" %in% colnames(list[[j]]$model)) {
    perm.sum[j,"perm"] <- list[[j]]$coefficients["perm"]                     # estimate
    perm.sum[j,"perm.sd"] <- coef(summary(list[[j]]))[,"Std. Error"]["perm"] # std. error
    perm.sum[j,"perm.p"] <- coef(summary(list[[j]]))[,"Pr(>|z|)"]["perm"]    # p-value 
