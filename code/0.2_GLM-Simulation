                      max.sum = sum(max.sum),                           # 1/3 models
                      sum.days.above.21 = sum(sum.days.above.21),       # 2/3 models
                      min.wint = sum(min.wint),                         # 1/3 models
                      wint.days.below.neg5 = sum(wint.days.below.neg5), # 2/3 models
                      avgEVI.lag = sum(avgEVI.lag),                     # 3/3 models
