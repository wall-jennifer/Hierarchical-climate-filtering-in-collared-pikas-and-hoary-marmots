                      perm = sum(perm),                                 # 3/3 models
                      wint.days.above.0 = sum(wint.days.above.0)) %>%  # 2/3 models
  pivot_longer(-AIC.mean) %>% rename(sum = value, variable = name) %>% 
  mutate(prop = ifelse((variable == "slope" | variable == "avgEVI.lag" | variable == "sden.mean" | variable == "perm"),
                       sum / 300, 
                       ifelse((variable == "sum.days.above.21" | variable == "wint.days.below.neg5" | variable == "wint.days.above.0"), 
                              sum / 200, sum / 100)))


