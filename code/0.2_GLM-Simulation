### GLM Simulation Code


## Import libraries
library(tidyverse)
library(gridExtra) # Make plots align together

## Import data
data <- read.csv("Opportunistic-surveys-COPI.csv")

### For this analysis - better to have only 63 absences so they match 1:1 with pres.
### Best way?? Can randomly remove them. They are already filtered to not within 500 m


### For loop to randomize the points I have
times <- 100 # iterations
list.aa <- list()
list.ab <- list()
list.bb <- list()

rglm.aa <- data.frame("AIC" = double(), "slope" = logical(), 
                      "max.sum" = logical(),
                      "sum.days.above.21"= logical(), 
                      "min.wint"= logical(),
                      "wint.days.below.neg5"= logical(), 
                      "avgEVI.lag"= logical(),
                      "sden.mean"= logical(), 
                      "perm"= logical(),
                      "wint.days.above.0"= logical())
rglm.ab <- data.frame("AIC" = double(), "slope" = logical(), 
                      "max.sum" = logical(),
                      "sum.days.above.21"= logical(), 
                      "min.wint"= logical(),
                      "wint.days.below.neg5"= logical(), 
                      "avgEVI.lag"= logical(),
                      "sden.mean"= logical(), 
                      "perm"= logical(),
                      "wint.days.above.0"= logical())
rglm.bb <- data.frame("AIC" = double(), "slope" = logical(), 
                      "max.sum" = logical(),
                      "sum.days.above.21"= logical(), 
                      "min.wint"= logical(),
                      "wint.days.below.neg5"= logical(), 
                      "avgEVI.lag"= logical(),
                      "sden.mean"= logical(), 
                      "perm"= logical(),
                      "wint.days.above.0"= logical())

for(i in 1:times){
  subset <- sample(1:nrow(data[data$Pres == 0,]), 63, replace = F)
  data.sub <- data[data$Pres == 0,] %>% .[subset,] %>% 
    add_row(data[data$Pres == 1,]) %>% 
    select(Pres, slope, max.sum, sum.days.above.21, min.wint, wint.days.below.neg5,
           avgEVI.lag, sden.mean, perm, wint.days.above.0, ID, x.x, y.x) %>%
    mutate_at(c("slope", "max.sum", "sum.days.above.21", "min.wint",
              "wint.days.below.neg5", "avgEVI.lag", "sden.mean", "perm",
              "wint.days.above.0"), ~(scale(.) %>% as.vector))
  
  # run glm for this iteration
  glm.aa <- glm(Pres ~ slope + sum.days.above.21 + min.wint + avgEVI.lag + sden.mean + perm,
               family = binomial, data = data.sub)
  glm.ab <- glm(Pres ~ slope + sum.days.above.21 + wint.days.below.neg5 + avgEVI.lag + sden.mean + perm + wint.days.above.0,
               family = binomial, data = data.sub)
  glm.bb <- glm(Pres ~ slope + max.sum + wint.days.below.neg5 + avgEVI.lag + sden.mean + perm + wint.days.above.0,
               family = binomial, data = data.sub)
  
  # Perform backward stepwise selection using AIC
  step_aa <- step(glm.aa, direction = "backward")
  step_ab <- step(glm.ab, direction = "backward")
  step_bb <- step(glm.bb, direction = "backward")
  
  # save everything in a list
  list.aa[[i]] <- step_aa
  list.ab[[i]] <- step_ab
  list.bb[[i]] <- step_bb
  
  # save df of summary details for each
  rglm.aa[i,] <- colnames(rglm.aa) %in% colnames(step_aa$model)
  rglm.aa[i,] <- rglm.aa[i,] %>% mutate(AIC = step_aa$aic)
  
  rglm.ab[i,] <- colnames(rglm.ab) %in% colnames(step_ab$model)
  rglm.ab[i,] <- rglm.ab[i,] %>% mutate(AIC = step_ab$aic)
    
  rglm.bb[i,] <- colnames(rglm.bb) %in% colnames(step_bb$model) 
  rglm.bb[i,] <- rglm.bb[i,] %>% mutate(AIC = step_bb$aic)
}

list <- c(list.aa, list.ab, list.bb)

rglm.aa.df <- rglm.aa %>% mutate(model = "aa")
rglm.ab.df <- rglm.ab %>% mutate(model = "ab")
rglm.bb.df <- rglm.bb %>% mutate(model = "bb")

rglm.df <- rglm.aa.df %>% add_row(rglm.ab.df) %>% add_row(rglm.bb.df)

